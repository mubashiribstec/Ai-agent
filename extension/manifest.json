{
  "manifest_version": 3,
  "name": "Xplogent Browser Control",
  "version": "1.0.0",
  "description": "Let your Xplogent agent see your open tabs and control your real Chrome browser.",
  "permissions": ["tabs", "scripting", "activeTab", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Xplogent" },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle", "all_frames": false }
  ]
}
