# ─── Xplogent environment ────────────────────────────────────────────────
# Copy to `.env` and fill in what you need. Ollama needs nothing here.

# Active provider/model (overrides config/default.yaml). Examples:
#   ollama:llama3.1   openai:gpt-4o   anthropic:claude-sonnet-4-6   openrouter:meta-llama/llama-3.1-70b-instruct
XPLOGENT_MODEL=ollama:llama3.1

# Local Ollama (default; no key needed)
OLLAMA_HOST=http://localhost:11434

# Hosted providers (only the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# API server
XPLOGENT_API_HOST=127.0.0.1
XPLOGENT_API_PORT=8765

# Data directory (memory db, skills, logs). Defaults to ~/.xplogent
# XPLOGENT_HOME=
